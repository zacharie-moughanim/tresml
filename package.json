{
  "name": "tresml",
  "displayName": "TresML",
  "description": "TresML language extension",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
    ],
    "languages": [
      {
        "id": "tresml",
        "extensions": [".tml"],
        "aliases": ["TresML"],
        "filenames": [],
        "configuration": "./tml-language-configuration.json",
        "icon": {
          "light": "./icons/tresml_light.svg",
          "dark": "./icons/tresml_dark.svg"
        }
      },
      {
        "id": "tresml_script",
        "configuration": "./tml-scr-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tresml",
        "scopeName": "source.tml",
        "path": "./syntaxes/tresml.tmGrammar.json",
        "embeddedLanguages": {
          "meta.embedded.html": "html"
        }
      },
      {
        "scopeName": "tresml.tresml_script.block",
        "path": "./syntaxes/tresml_script_embedded.tmGrammar.json",
        "injectTo": [
          "source.tml"
        ],
        "embeddedLanguages": {
          "meta.embedded.tresml_script": "tresml_script"
        }
      },
      {
        "language": "tresml_script",
        "scopeName": "source.tml_scr",
        "path": "./syntaxes/tresml_script.tmGrammar.json",
        "embeddedLanguages": {
          "meta.embedded.tresml": "tresml",
          "meta.embedded.js": "javascript",
          "meta.embedded.html": "html"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.105.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
